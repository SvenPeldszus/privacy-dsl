<?xml version="1.0" encoding="UTF-8"?>
<description:Group xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:description="http://www.eclipse.org/sirius/description/1.1.0" xmlns:description_1="http://www.eclipse.org/sirius/diagram/description/1.1.0" xmlns:properties="http://www.eclipse.org/sirius/properties/1.0.0" xmlns:properties-ext-widgets-reference="http://www.eclipse.org/sirius/properties/1.0.0/ext/widgets/reference" xmlns:style="http://www.eclipse.org/sirius/diagram/description/style/1.1.0" xmlns:tool="http://www.eclipse.org/sirius/diagram/description/tool/1.1.0" xmlns:tool_1="http://www.eclipse.org/sirius/description/tool/1.1.0" name="project" version="15.4.0.202401051836">
  <ownedViewpoints name="eDFD">
    <ownedRepresentations xsi:type="description_1:DiagramDescription" name="extendedDFD" initialisation="true" domainClass="model::EDFD" enablePopupBars="true">
      <metamodel href="../../org.secdfd.model/model/model.ecore#/"/>
      <defaultLayer name="eDFDiagram">
        <nodeMappings name="Assumption" domainClass="model::Assumption">
          <style xsi:type="style:DotDescription" labelSize="12" labelPosition="node" resizeKind="NSEW">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_orange']"/>
          </style>
        </nodeMappings>
        <nodeMappings name="DataStore" domainClass="model::DataStore">
          <style xsi:type="style:WorkspaceImageDescription" labelSize="12" sizeComputationExpression="-1" labelPosition="node" resizeKind="NSEW" workspacePath="/org.secdfd.model.editor/220px-Data-flow-diagram-notation.svg.png">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
          </style>
        </nodeMappings>
        <nodeMappings name="ExternalEntity" domainClass="model::ExternalEntity">
          <style xsi:type="style:SquareDescription" borderSizeComputationExpression="2" labelSize="12" sizeComputationExpression="10" labelPosition="node" resizeKind="NSEW">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
          </style>
        </nodeMappings>
        <nodeMappings name="Process" domainClass="model::Process">
          <borderedNodeMappings name="Contract" semanticCandidatesExpression="feature:contract" domainClass="model::ContractBase">
            <style xsi:type="style:DotDescription" labelSize="12" showIcon="false" labelExpression="feature:Task" labelPosition="node" resizeKind="NSEW">
              <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <labelFormat>bold</labelFormat>
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_chocolate']"/>
            </style>
            <conditionnalStyles predicateExpression="aql:self.oclIsKindOf(model::ClassificationContract)">
              <style xsi:type="style:DotDescription" labelSize="12" showIcon="false" labelExpression="'Classification'" labelPosition="node" resizeKind="NSEW">
                <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <labelFormat>bold</labelFormat>
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_blue']"/>
              </style>
            </conditionnalStyles>
            <conditionnalStyles predicateExpression="aql:self.oclIsKindOf(model::ClusteringContract)">
              <style xsi:type="style:DotDescription" labelSize="12" showIcon="false" labelExpression="'Clustering'" labelPosition="node" resizeKind="NSEW">
                <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <labelFormat>bold</labelFormat>
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='green']"/>
              </style>
            </conditionnalStyles>
            <conditionnalStyles predicateExpression="aql:self.oclIsKindOf(model::DecisionMakingContract)">
              <style xsi:type="style:DotDescription" labelSize="12" showIcon="false" labelExpression="'DecisionMaking'" labelPosition="node" resizeKind="NSEW">
                <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <labelFormat>bold</labelFormat>
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_yellow']"/>
              </style>
            </conditionnalStyles>
            <conditionnalStyles predicateExpression="aql:self.oclIsKindOf(model::RecommendationContract)">
              <style xsi:type="style:DotDescription" labelSize="12" showIcon="false" labelExpression="'Recommendation'" labelPosition="node" resizeKind="NSEW">
                <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <labelFormat>bold</labelFormat>
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_purple']"/>
              </style>
            </conditionnalStyles>
            <conditionnalStyles predicateExpression="aql:self.oclIsKindOf(model::PredictionContract)">
              <style xsi:type="style:DotDescription" labelSize="12" showIcon="false" labelExpression="'Prediction'" labelPosition="node" resizeKind="NSEW">
                <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <labelFormat>bold</labelFormat>
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_orange']"/>
              </style>
            </conditionnalStyles>
            <conditionnalStyles predicateExpression="aql:self.oclIsKindOf(model::DimensionalityReductionContract)">
              <style xsi:type="style:DotDescription" labelSize="12" showIcon="false" labelExpression="'DimensionalityReduction'" labelPosition="node" resizeKind="NSEW">
                <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <labelFormat>bold</labelFormat>
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_chocolate']"/>
              </style>
            </conditionnalStyles>
            <conditionnalStyles predicateExpression="aql:self.oclIsKindOf(model::DataGenerationContract)">
              <style xsi:type="style:DotDescription" labelSize="12" showIcon="false" labelExpression="'DataGeneration'" labelPosition="node" resizeKind="NSEW">
                <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <labelFormat>bold</labelFormat>
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='dark_green']"/>
              </style>
            </conditionnalStyles>
          </borderedNodeMappings>
          <style xsi:type="style:EllipseNodeDescription" borderSizeComputationExpression="2" labelSize="12" sizeComputationExpression="10" labelPosition="node" resizeKind="NORTH_SOUTH">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
          </style>
        </nodeMappings>
        <nodeMappings name="Asset" domainClass="model::Asset">
          <borderedNodeMappings name="Value" semanticCandidatesExpression="feature:eAllContents" domainClass="model::Value">
            <style xsi:type="style:LozengeNodeDescription" labelSize="12" labelExpression="feature:Objective" labelPosition="node" resizeKind="NSEW" widthComputationExpression="5" heightComputationExpression="3">
              <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_yellow']"/>
            </style>
            <conditionnalStyles predicateExpression="[self.Level = Level::C/]">
              <style xsi:type="style:LozengeNodeDescription" labelSize="12" labelExpression="feature:Objective" labelPosition="node" resizeKind="NSEW">
                <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='red']"/>
              </style>
            </conditionnalStyles>
            <conditionnalStyles predicateExpression="[self.Level = Level::H/]">
              <style xsi:type="style:LozengeNodeDescription" labelSize="12" labelExpression="aql:self.Objective.toString().first(2)" labelPosition="node" resizeKind="NSEW" widthComputationExpression="5" heightComputationExpression="3">
                <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='dark_orange']"/>
              </style>
            </conditionnalStyles>
            <conditionnalStyles predicateExpression="[self.Level = Level::M/]">
              <style xsi:type="style:LozengeNodeDescription" labelSize="12" labelExpression="feature:Objective" labelPosition="node" resizeKind="NSEW" widthComputationExpression="5" heightComputationExpression="3">
                <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='orange']"/>
              </style>
            </conditionnalStyles>
            <conditionnalStyles predicateExpression="[self.Level = Level::L/]">
              <style xsi:type="style:LozengeNodeDescription" labelSize="12" labelExpression="feature:Objective" labelPosition="node" resizeKind="NSEW">
                <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='yellow']"/>
              </style>
            </conditionnalStyles>
            <conditionnalStyles predicateExpression="[self.Level = Level::N/]">
              <style xsi:type="style:LozengeNodeDescription" labelSize="12" labelExpression="feature:Objective" labelPosition="node" resizeKind="NSEW">
                <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='green']"/>
              </style>
            </conditionnalStyles>
          </borderedNodeMappings>
          <style xsi:type="style:LozengeNodeDescription" labelSize="12" sizeComputationExpression="4" labelPosition="node" resizeKind="NSEW" widthComputationExpression="10" heightComputationExpression="3">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='gray']"/>
          </style>
        </nodeMappings>
        <edgeMappings name="Flow" sourceMapping="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='ExternalEntity'] //@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='Process'] //@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='DataStore']" targetMapping="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='ExternalEntity'] //@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='Process'] //@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='DataStore']" targetFinderExpression="feature:target" sourceFinderExpression="feature:source" domainClass="model::Flow" useDomainElement="true">
          <style sizeComputationExpression="2">
            <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='gray']"/>
            <beginLabelStyleDescription labelSize="12">
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            </beginLabelStyleDescription>
            <centerLabelStyleDescription labelSize="12" labelExpression="aql:self.assets->collect(a | a.name)">
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            </centerLabelStyleDescription>
          </style>
          <conditionnalStyles predicateExpression="service:isFlowHighlightedEnhancedStatic">
            <style sizeComputationExpression="4">
              <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='blue']"/>
              <centerLabelStyleDescription labelSize="12" labelExpression="aql:self.assets->collect(a | a.name)">
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='red']"/>
              </centerLabelStyleDescription>
            </style>
          </conditionnalStyles>
        </edgeMappings>
        <edgeMappings name="AssetToSource" sourceMapping="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='Asset']" targetMapping="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='DataStore'] //@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='ExternalEntity'] //@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='Process']" targetFinderExpression="feature:source">
          <style lineStyle="dash" sizeComputationExpression="2">
            <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='gray']"/>
            <centerLabelStyleDescription labelSize="12">
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            </centerLabelStyleDescription>
          </style>
        </edgeMappings>
        <edgeMappings name="SourceToAssumption" sourceMapping="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='Process'] //@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='DataStore'] //@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='ExternalEntity']" targetMapping="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='Assumption']" targetFinderExpression="feature:assumption">
          <style lineStyle="dot" sizeComputationExpression="2">
            <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='gray']"/>
            <centerLabelStyleDescription labelSize="12">
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            </centerLabelStyleDescription>
          </style>
        </edgeMappings>
        <toolSections name="tools">
          <ownedTools xsi:type="tool:NodeCreationDescription" name="createAsset" nodeMappings="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='Asset']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="model::Asset" referenceName="asset">
                  <subModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:instance">
                    <subModelOperations xsi:type="tool_1:CreateInstance" typeName="model::Value" referenceName="value"/>
                  </subModelOperations>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool:EdgeCreationDescription" name="createDataFlow" edgeMappings="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@edgeMappings[name='Flow']">
            <sourceVariable name="source"/>
            <targetVariable name="target"/>
            <sourceViewVariable name="sourceView"/>
            <targetViewVariable name="targetView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:source">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="model::Flow" referenceName="outflows">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="source" valueExpression="var:source"/>
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="target" valueExpression="var:target"/>
                  <subModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:target">
                    <subModelOperations xsi:type="tool_1:SetValue" featureName="inflows" valueExpression="var:instance"/>
                  </subModelOperations>
                </subModelOperations>
                <subModelOperations xsi:type="tool_1:SetValue" featureName="outflows" valueExpression="feature:outflows"/>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="createProcess" nodeMappings="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='Process']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="model::Process" referenceName="elements">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="name"/>
                </subModelOperations>
                <subModelOperations xsi:type="tool_1:ArrangeLayout"/>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="createDataStore" nodeMappings="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='DataStore']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="model::DataStore" referenceName="elements">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="name"/>
                </subModelOperations>
                <subModelOperations xsi:type="tool_1:ArrangeLayout"/>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="createExternalEntity" nodeMappings="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='ExternalEntity']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="model::ExternalEntity" referenceName="elements">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="name"/>
                </subModelOperations>
                <subModelOperations xsi:type="tool_1:ArrangeLayout"/>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="createAssumption" nodeMappings="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='Assumption']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="model::Assumption" referenceName="assumption">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="Objective" valueExpression="aql:var:assumpObj.split(',')"/>
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="Layer" valueExpression="var:assumpLayer"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
            <askStringVariable name="assumpObj" prompt="Objectives (comma-separated)"/>
            <askChoiceVariable name="assumpLayer" candidatesExpression="aql:ecore::Layer::Transport.oclType().eAllInstances()" multiple="false" prompt="Layer"/>
          </ownedTools>
          <ownedTools xsi:type="tool:EdgeCreationDescription" name="CreateAssetToSource" edgeMappings="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@edgeMappings[name='AssetToSource']">
            <sourceVariable name="source"/>
            <targetVariable name="target"/>
            <sourceViewVariable name="sourceView"/>
            <targetViewVariable name="targetView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:source">
                <subModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:target">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="assets" valueExpression="var:source"/>
                </subModelOperations>
                <subModelOperations xsi:type="tool_1:SetValue" featureName="source" valueExpression="var:target"/>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool_1:SelectionWizardDescription" name="createAssumptionForElement" elementsToSelect="var:element" candidatesExpression="var:container">
            <element name="element"/>
            <containerView name="containerView"/>
            <container name="container"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:element">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="model::Assumption" referenceName="assumption"/>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="createAssetValue" nodeMappings="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='Asset']/@borderedNodeMappings[name='Value']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="model::Value" referenceName="value"/>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="createContract" nodeMappings="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='Process']/@borderedNodeMappings[name='Contract']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="model::SecurityContract" referenceName="contract">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="name" valueExpression="aql:var:respAction.name"/>
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="Task" valueExpression="var:respAction"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
            <askChoiceVariable name="respAction" multiple="false" candidatesExpression="aql:ecore::ContractType.eLiterals" prompt="Task"/>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="createClassificationContract" nodeMappings="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='Process']/@borderedNodeMappings[name='Contract']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="model::ClassificationContract" referenceName="contract">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="name" valueExpression="aql:if var:contractName &lt;> null and not var:contractName.oclIsUndefined() then var:contractName else 'Classification' endif"/>
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="PClass" valueExpression="aql:if var:pClassValue &lt;> null and not var:pClassValue.oclIsUndefined() then var:pClassValue else model::Level::L endif"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
            <askStringVariable name="contractName" prompt="Contract Name (optional)"/>
            <askChoiceVariable name="pClassValue" candidatesExpression="aql:model::Level.eLiterals" candidateDisplayExpression="aql:candidate.name" prompt="Privacy Level of Most Critical Class Label" multiple="false"/>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="createClusteringContract" nodeMappings="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='Process']/@borderedNodeMappings[name='Contract']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="model::ClusteringContract" referenceName="contract">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="name" valueExpression="aql:if var:contractName &lt;> null and not var:contractName.oclIsUndefined() then var:contractName else 'Clustering' endif"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
            <askStringVariable name="contractName" prompt="Contract Name (optional)"/>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="createDecisionMakingContract" nodeMappings="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='Process']/@borderedNodeMappings[name='Contract']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="model::DecisionMakingContract" referenceName="contract">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="name" valueExpression="aql:if var:contractName &lt;> null and not var:contractName.oclIsUndefined() then var:contractName else 'DecisionMaking' endif"/>
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="PAction" valueExpression="aql:if var:pActionValue &lt;> null and not var:pActionValue.oclIsUndefined() then var:pActionValue else model::Level::L endif"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
            <askStringVariable name="contractName" prompt="Contract Name (optional)"/>
            <askChoiceVariable name="pActionValue" candidatesExpression="aql:model::Level.eLiterals" candidateDisplayExpression="aql:candidate.name" prompt="What is the privacy level of the most privacy-critical decision action?" multiple="false"/>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="createRecommendationContract" nodeMappings="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='Process']/@borderedNodeMappings[name='Contract']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="model::RecommendationContract" referenceName="contract">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="name" valueExpression="aql:if var:contractName &lt;> null and not var:contractName.oclIsUndefined() then var:contractName else 'Recommendation' endif"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
            <askStringVariable name="contractName" prompt="Contract Name (optional)"/>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="createPredictionContract" nodeMappings="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='Process']/@borderedNodeMappings[name='Contract']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="model::PredictionContract" referenceName="contract">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="name" valueExpression="aql:if var:contractName &lt;> null and not var:contractName.oclIsUndefined() then var:contractName else 'Prediction' endif"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
            <askStringVariable name="contractName" prompt="Contract Name (optional)"/>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="createDimensionalityReductionContract" nodeMappings="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='Process']/@borderedNodeMappings[name='Contract']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="model::DimensionalityReductionContract" referenceName="contract">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="name" valueExpression="aql:if var:contractName &lt;> null and not var:contractName.oclIsUndefined() then var:contractName else 'DimensionalityReduction' endif"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
            <askStringVariable name="contractName" prompt="Contract Name (optional)"/>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="createDataGenerationContract" nodeMappings="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='Process']/@borderedNodeMappings[name='Contract']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="model::DataGenerationContract" referenceName="contract">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="name" valueExpression="aql:if var:contractName &lt;> null and not var:contractName.oclIsUndefined() then var:contractName else 'DataGeneration' endif"/>
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="Direction" valueExpression="aql:if var:directionValue &lt;> null and not var:directionValue.oclIsUndefined() and var:directionValue.instance &lt;> null then var:directionValue.instance else model::DataGenerationDirection::PRESERVE endif"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
            <askStringVariable name="contractName" prompt="Contract Name (optional)"/>
            <askChoiceVariable name="directionValue" candidatesExpression="aql:model::DataGenerationDirection.eLiterals" candidateDisplayExpression="aql:candidate.name" prompt="Does generation reduce, preserve, or elevate privacy?" multiple="false"/>
          </ownedTools>
          <ownedTools xsi:type="tool_1:SelectionWizardDescription" name="highlightAssetFlows" precondition="aql:true" elementsToSelect="var:selectedAsset" candidatesExpression="aql:self.asset" multiple="true">
            <element name="selectedAsset"/>
            <containerView name="containerView"/>
            <container name="container"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:selectedAsset">
                <subModelOperations xsi:type="tool_1:ExternalJavaAction" name="highlightAsset" id="org.secdfd.model.presentation.Services.setHighlightedAsset">
                  <parameters name="asset" value="var:selectedAsset"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool_1:SelectionWizardDescription" name="clearHighlights" precondition="aql:true" elementsToSelect="var:container" candidatesExpression="aql:self">
            <element name="container"/>
            <containerView name="containerView"/>
            <container name="container"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ExternalJavaAction" name="clearHighlights" id="org.secdfd.model.presentation.Services.clearHighlights"/>
            </initialOperation>
          </ownedTools>
          <decorationDescriptions xsi:type="description_1:DiagramDecorationDescription">
            <triggers>
              <trigger xsi:type="tool_1:PopupMenu" name="Clear Highlights">
                <firstModelOperations xsi:type="tool_1:ExternalJavaAction" name="clearHighlights" id="org.secdfd.model.presentation.Services.clearHighlights"/>
              </trigger>
            </triggers>
          </decorationDescriptions>
        </toolSections>
      </defaultLayer>
      <additionalLayers name="ThreatModeling">
        <containerMappings name="TrustZone" semanticCandidatesExpression="feature:trustzones" domainClass="model::TrustZone" labelExpression="feature:name">
          <subNodeMappings name="AttackerProfile" semanticCandidatesExpression="feature:attackerprofile" domainClass="model::AttackerProfile" labelExpression="feature:name">
            <style xsi:type="style:DotDescription" labelSize="10" sizeComputationExpression="6">
              <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='red']"/>
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_red']"/>
            </style>
          </subNodeMappings>
          <subNodeMappings xsi:type="description_1:NodeMappingImport" name="ProcInTZ" semanticCandidatesExpression="feature:elements" importedMapping="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='Process']"/>
          <subNodeMappings xsi:type="description_1:NodeMappingImport" name="StoreInTZ" semanticCandidatesExpression="feature:elements" importedMapping="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='DataStore']"/>
          <subNodeMappings xsi:type="description_1:NodeMappingImport" name="ExtEntInTZ" semanticCandidatesExpression="feature:elements" importedMapping="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='ExternalEntity']"/>
          <subNodeMappings xsi:type="description_1:NodeMappingImport" name="AssetInTZ" semanticCandidatesExpression="aql:self.elements.assets->select(a | self.elements->includes(a.source))" importedMapping="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer/@nodeMappings[name='Asset']"/>
          <subContainerMappings xsi:type="description_1:ContainerMappingImport" name="NestedTZ" semanticCandidatesExpression="aql:self.subzones" reusedNodeMappings="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@additionalLayers[name='ThreatModeling']/@containerMappings[name='TrustZone']/@subNodeMappings[name='AttackerProfile'] //@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@additionalLayers[name='ThreatModeling']/@containerMappings[name='TrustZone']/@subNodeMappings[name='ExtEntInTZ'] //@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@additionalLayers[name='ThreatModeling']/@containerMappings[name='TrustZone']/@subNodeMappings[name='ProcInTZ'] //@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@additionalLayers[name='ThreatModeling']/@containerMappings[name='TrustZone']/@subNodeMappings[name='StoreInTZ'] //@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@additionalLayers[name='ThreatModeling']/@containerMappings[name='TrustZone']/@subNodeMappings[name='AssetInTZ']" importedMapping="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@additionalLayers[name='ThreatModeling']/@containerMappings[name='TrustZone']"/>
          <style xsi:type="style:FlatContainerStyleDescription" borderSizeComputationExpression="2" labelSize="12" roundedCorner="true" resizeKind="NSEW">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='dark_blue']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='dark_blue']"/>
            <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='alice_blue']"/>
            <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_gray']"/>
          </style>
        </containerMappings>
        <toolSections name="ThreatTools">
          <ownedTools xsi:type="tool:ContainerCreationDescription" name="createTrustZone" precondition="aql:self.oclIsKindOf(model::EDFD)" containerMappings="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@additionalLayers[name='ThreatModeling']/@containerMappings[name='TrustZone']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="model::TrustZone" referenceName="trustzones">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="name" valueExpression="var:tzName"/>
                </subModelOperations>
                <subModelOperations xsi:type="tool_1:ArrangeLayout"/>
              </firstModelOperations>
            </initialOperation>
            <askStringVariable name="tzName" prompt="Trust Zone name"/>
          </ownedTools>
          <ownedTools xsi:type="tool:ContainerCreationDescription" name="createSubZone" precondition="aql:self.oclIsKindOf(model::TrustZone)" containerMappings="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@additionalLayers[name='ThreatModeling']/@containerMappings[name='TrustZone']/@subContainerMappings[name='NestedTZ']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="model::TrustZone" referenceName="subzones">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="name" valueExpression="var:subName"/>
                </subModelOperations>
                <subModelOperations xsi:type="tool_1:ArrangeLayout"/>
              </firstModelOperations>
            </initialOperation>
            <askStringVariable name="subName" prompt="Sub-zone name"/>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="createAttackerProfile" nodeMappings="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@additionalLayers[name='ThreatModeling']/@containerMappings[name='TrustZone']/@subNodeMappings[name='AttackerProfile']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="model::AttackerProfile" referenceName="attackerprofile">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="name" valueExpression="var:attName"/>
                </subModelOperations>
                <subModelOperations xsi:type="tool_1:SetValue" featureName="attackerprofile" valueExpression="var:instance"/>
                <subModelOperations xsi:type="tool_1:ArrangeLayout"/>
              </firstModelOperations>
            </initialOperation>
            <askStringVariable name="attName" prompt="Attacker name"/>
          </ownedTools>
          <ownedTools xsi:type="tool_1:SelectionWizardDescription" name="RemoveElementFromTrustZone" precondition="aql:self.oclIsKindOf(model::TrustZone)" elementsToSelect="var:elementToRemove" candidatesExpression="aql:self.elements">
            <element name="elementToRemove"/>
            <containerView name="containerView"/>
            <container name="container"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:Unset" featureName="elements" elementExpression="var:elementToRemove"/>
              </firstModelOperations>
              <subModelOperations xsi:type="tool_1:ArrangeLayout"/>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool:SelectionWizardDescription" name="highlightAssetFlows" candidatesExpression="aql:self.asset" elementsToSelect="var:selectedAsset" precondition="aql:true">
    <element name="selectedAsset"/>
    <containerView name="containerView"/>
    <container name="container"/>
    <initialOperation>
      <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:selectedAsset">
                <subModelOperations xsi:type="tool_1:ExternalJavaAction" name="highlightAsset" id="org.secdfd.model.presentation.Services.setHighlightedAsset">
                  <parameters name="asset" value="var:selectedAsset"/>
                </subModelOperations>
              </firstModelOperations>
    </initialOperation>
  </ownedTools>
        </toolSections>
        <layerDependencies href="//@ownedViewpoints[name='eDFD']/@ownedRepresentations[name='extendedDFD']/@defaultLayer"/>
      </additionalLayers>
    </ownedRepresentations>
    <ownedJavaExtensions qualifiedClassName="org.secdfd.model.presentation.Services"/>
  </ownedViewpoints>
  <extensions xsi:type="properties:ViewExtensionDescription" name="sirius_default_rules_properties">
    <categories name="Default">
      <pages name="sirius_default_rules_defaultpage" labelExpression="aql:input.emfEditServices(self).getTabName()" semanticCandidateExpression="aql:input.getAllSemanticElements()" groups="//@extensions.0/@categories.0/@groups.0"/>
      <groups name="sirius_default_rules_defaultgroup" labelExpression="Properties" semanticCandidateExpression="var:self" preconditionExpression="">
        <controls xsi:type="properties:DynamicMappingForDescription" name="sirius_default_rules_structural_features_for" iterator="eStructuralFeature" iterableExpression="aql:input.emfEditServices(self).getEStructuralFeatures()">
          <ifs name="classification_pClass_if" predicateExpression="aql:self.oclIsKindOf(model::ClassificationContract) and eStructuralFeature.name = 'PClass'">
            <widget xsi:type="properties:SelectDescription" name="classification_pClass_widget" labelExpression="What is the privacy level of the most privacy-critical class label?" helpExpression="Select the privacy label of your most critical class label: N = non-personal | L = privacy-relevant | M = personal | H = unique identifiers | C = special category" valueExpression="aql:if self.eGet(eStructuralFeature.name) &lt;> null then eStructuralFeature.eType.oclAsType(ecore::EEnum).getEEnumLiteralByLiteral(self.eGet(eStructuralFeature.name).toString()) else eStructuralFeature.eType.oclAsType(ecore::EEnum).getEEnumLiteralByLiteral('L') endif" candidatesExpression="aql:model::Level.eLiterals" candidateDisplayExpression="aql:candidate.name">
              <initialOperation>
                <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="aql:self.oclAsType(model::ClassificationContract)">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="PClass" valueExpression="aql:if newValue &lt;> null then newValue.instance else null endif"/>
                </firstModelOperations>
              </initialOperation>
            </widget>
          </ifs>
          <ifs name="decisionmaking_pAction_if" predicateExpression="aql:self.oclIsKindOf(model::DecisionMakingContract) and eStructuralFeature.name = 'PAction'">
            <widget xsi:type="properties:SelectDescription" name="decisionmaking_pAction_widget" labelExpression="What is the privacy level of the most privacy-critical decision action?" helpExpression="Evaluate all possible actions: N = non-personal | L = privacy-relevant | M = personal | H = unique identifiers | C = special category" valueExpression="aql:if self.eGet(eStructuralFeature.name) &lt;> null then eStructuralFeature.eType.oclAsType(ecore::EEnum).getEEnumLiteralByLiteral(self.eGet(eStructuralFeature.name).toString()) else eStructuralFeature.eType.oclAsType(ecore::EEnum).getEEnumLiteralByLiteral('L') endif" candidatesExpression="aql:model::Level.eLiterals" candidateDisplayExpression="aql:candidate.name">
              <initialOperation>
                <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="aql:self.oclAsType(model::DecisionMakingContract)">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="PAction" valueExpression="aql:if newValue &lt;> null then newValue.instance else null endif"/>
                </firstModelOperations>
              </initialOperation>
            </widget>
          </ifs>
          <ifs name="recommendation_s_if" predicateExpression="aql:self.oclIsKindOf(model::RecommendationContract) and eStructuralFeature.name = 'S'">
            <widget xsi:type="properties:CheckboxDescription" name="recommendation_s_widget" labelExpression="Is the ranked list recommended to a natural person?" helpExpression="Yes = tailored to an individual user; No = generic or B2B recommendations" valueExpression="aql:self.eGet(eStructuralFeature.name)">
              <initialOperation>
                <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="aql:input.emfEditServices(self).setValue(eStructuralFeature, newValue)"/>
              </initialOperation>
            </widget>
          </ifs>
          <ifs name="prediction_s_if" predicateExpression="aql:self.oclIsKindOf(model::PredictionContract) and eStructuralFeature.name = 'S'">
            <widget xsi:type="properties:CheckboxDescription" name="prediction_s_widget" labelExpression="Can the prediction output enable identification of a natural person?" helpExpression="Yes = output relates to identifiable person; No = aggregate/population-level data" valueExpression="aql:self.eGet(eStructuralFeature.name)">
              <initialOperation>
                <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="aql:input.emfEditServices(self).setValue(eStructuralFeature, newValue)"/>
              </initialOperation>
            </widget>
          </ifs>
          <ifs name="dimensionalityreduction_k_if" predicateExpression="aql:self.oclIsKindOf(model::DimensionalityReductionContract) and eStructuralFeature.name = 'K'">
            <widget xsi:type="properties:SelectDescription" name="dimensionalityreduction_k_widget" labelExpression="What is the reduction strength?" helpExpression="Select how many privacy levels your dimension reduction task reduces." valueExpression="aql:self.oclAsType(model::DimensionalityReductionContract).K" candidatesExpression="aql:Sequence{0, 1, 2, 3, 4}" candidateDisplayExpression="aql:if candidate = 0 then '0 - No reduction' else if candidate = 1 then '1 - Weak reduction' else if candidate = 2 then '2 - Moderate reduction' else if candidate = 3 then '3 - Strong reduction' else '4 - Very strong reduction' endif endif endif endif">
              <initialOperation>
                <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="aql:self.oclAsType(model::DimensionalityReductionContract)">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="K" valueExpression="aql:newValue"/>
                </firstModelOperations>
              </initialOperation>
            </widget>
          </ifs>
          <ifs name="datageneration_direction_if" predicateExpression="aql:self.oclIsKindOf(model::DataGenerationContract) and eStructuralFeature.name = 'Direction'">
            <widget xsi:type="properties:SelectDescription" name="datageneration_direction_widget" labelExpression="Does data generation reduce, preserve, or elevate privacy?" helpExpression="Reduce = lower privacy level; Preserve = keep same level; Elevate = raise privacy level" valueExpression="aql:if self.eGet(eStructuralFeature.name) &lt;> null then eStructuralFeature.eType.oclAsType(ecore::EEnum).getEEnumLiteralByLiteral(self.eGet(eStructuralFeature.name).toString()) else null endif" candidatesExpression="aql:eStructuralFeature.eType.oclAsType(ecore::EEnum).eLiterals" candidateDisplayExpression="aql:candidate.name">
              <initialOperation>
                <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="aql:input.emfEditServices(self).setValue(eStructuralFeature, if newValue &lt;> null then newValue.instance else null endif)"/>
              </initialOperation>
            </widget>
          </ifs>
          <ifs name="datageneration_k_if" predicateExpression="aql:self.oclIsKindOf(model::DataGenerationContract) and eStructuralFeature.name = 'K'">
            <widget xsi:type="properties:SelectDescription" name="datageneration_k_widget" labelExpression="By how many levels?" helpExpression="Select the number of privacy levels to change (only shown if not Preserve)" isEnabledExpression="aql:let direction = self.oclAsType(model::DataGenerationContract).Direction in direction &lt;> null and direction &lt;> model::DataGenerationDirection::PRESERVE" valueExpression="aql:self.oclAsType(model::DataGenerationContract).K" candidatesExpression="aql:Sequence{1, 2, 3, 4}" candidateDisplayExpression="aql:candidate.toString()">
              <initialOperation>
                <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="aql:self.oclAsType(model::DataGenerationContract)">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="K" valueExpression="aql:newValue"/>
                </firstModelOperations>
              </initialOperation>
            </widget>
          </ifs>
          <ifs name="sirius_default_rules_enum_many_if" predicateExpression="aql:eStructuralFeature.name = 'Task' and eStructuralFeature.oclIsKindOf(ecore::EAttribute) and eStructuralFeature.many and eStructuralFeature.eType.oclIsKindOf(ecore::EEnum) and self.oclIsKindOf(model::SecurityContract)">
            <widget xsi:type="properties:SelectDescription" name="sirius_default_rules_enum_many_action" labelExpression="aql:input.emfEditServices(self).getText(eStructuralFeature)+':'" helpExpression="aql:input.emfEditServices(self).getDescription(eStructuralFeature)" isEnabledExpression="aql:eStructuralFeature.changeable" valueExpression="aql:self.oclAsType(model::SecurityContract).Task" candidatesExpression="aql:eStructuralFeature.eType.oclAsType(ecore::EEnum).eLiterals" candidateDisplayExpression="aql:candidate.name" multiple="true">
              <initialOperation>
                <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="aql:self">
                  <subModelOperations xsi:type="tool_1:ExternalJavaAction" name="setMultiValuedEnumValue" id="org.secdfd.model.presentation.Services.setMultiValuedEnumValue">
                    <parameters name="object" value="aql:self"/>
                    <parameters name="feature" value="aql:eStructuralFeature"/>
                    <parameters name="newValue" value="aql:newValue"/>
                  </subModelOperations>
                </firstModelOperations>
              </initialOperation>
            </widget>
          </ifs>
          <ifs name="sirius_default_rules_enum_many_generic_if" predicateExpression="aql:eStructuralFeature.oclIsKindOf(ecore::EAttribute) and eStructuralFeature.many and eStructuralFeature.eType.oclIsKindOf(ecore::EEnum) and eStructuralFeature.name &lt;> 'Task'">
            <widget xsi:type="properties:ListDescription" name="sirius_default_rules_enum_many_generic" labelExpression="aql:input.emfEditServices(self).getText(eStructuralFeature)+':'" helpExpression="aql:input.emfEditServices(self).getDescription(eStructuralFeature)" isEnabledExpression="aql:eStructuralFeature.changeable" valueExpression="aql:self.eGet(eStructuralFeature.name)" displayExpression="aql:value.toString()">
