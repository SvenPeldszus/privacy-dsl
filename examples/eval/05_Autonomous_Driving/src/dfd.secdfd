EDFD Autonomous_Driving [
    assets:
         Asset "Camera images" 
         	type: String 
         	values: [ M P ] 
         	source: input_data_store 
         	targets: Classifier ,

         Asset "Driving Decisions" 
         	type: String 
         	source: Classifier 
         	targets: output_data_store 
         	
	elements:
        
        Process Classifier [ 
        	contracts: ClassificationFixed [ "Camera images" PModel = N :: "Driving Decisions" ] 
            incoming flows: "input_data_store.F1" 
            outgoing flows: F2 [ assets: "Driving Decisions" source: Classifier targets: output_data_store ]
		] , 
        
        DataStore input_data_store [ 
        	outgoing flows: F1 [ 
        		assets: "Camera images" 
        		source: input_data_store 
        		targets: Classifier
        	]
        ] , 
        
        DataStore output_data_store [ 
        	incoming flows: "Classifier.F2"
        ]
]