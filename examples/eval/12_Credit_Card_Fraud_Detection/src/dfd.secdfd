EDFD Credit_Card_Fraud_Detection[
    assets:
         Asset  
            CreditCardTransactions type: String values: [ M P ] source: input_data_store targets: Classifier ,

         Asset 
            SuspiciousTransactions type: String source: Classifier targets: output_data_store elements:
        
        Process 
            Classifier [ contracts: Transformation [ CreditCardTransactions :: SuspiciousTransactions ] incoming flows: "input_data_store.F1" outgoing flows: F2 [ assets: SuspiciousTransactions source: Classifier targets: output_data_store ] ] , DataStore input_data_store [ outgoing flows: F1 [ assets: CreditCardTransactions source: input_data_store targets: Classifier ] ] , DataStore output_data_store [ incoming flows: "Classifier.F2" ] ]