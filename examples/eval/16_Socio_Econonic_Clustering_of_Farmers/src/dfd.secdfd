EDFD Socio_Economic_Clustering_Of_Farmers[
    assets:
         Asset  
            SocioEconomicData type: String values: [ M P ] source: input_data_store targets: ^Clustering ,

         Asset 
            ClusterAssignmentVector type: String source: ^Clustering targets: output_data_store elements:
        
        Process 
            ^Clustering [ contracts: Clustering [ SocioEconomicData :: ClusterAssignmentVector ] incoming flows: "input_data_store.F1" outgoing flows: F2 [ assets: ClusterAssignmentVector source: ^Clustering targets: output_data_store ] ] , DataStore input_data_store [ outgoing flows: F1 [ assets: SocioEconomicData source: input_data_store targets: ^Clustering ] ] , DataStore output_data_store [ incoming flows: "Clustering.F2" ] ]